generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Post {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  coverImage  String?
  published   Boolean    @default(false)
  featured    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contents    Content[]
  tags        TagOnPost[]
}

model Content {
  id       String  @id @default(cuid())
  postId   String
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  type     String  // "text" or "image"
  content  String? // text content (stored as text, supports long content)
  images   String? // JSON array of image paths
  order    Int
}

model Tag {
  id    String      @id @default(cuid())
  name  String      @unique
  slug  String      @unique
  posts TagOnPost[]
}

model TagOnPost {
  postId String
  tagId  String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Ebook {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  coverImage    String?
  price         Float
  originalPrice Float?
  category      String   // neurociencia, diabetes, nutricao, sabedoria, mudanca-habitos, microbiota
  targetAudience String?
  buyLink       String?  // Kiwify link
  published     Boolean  @default(false)
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Sales page fields
  salesHeadline   String?
  salesBullets    String[]  @default([])
  kiwifyUrl       String?
  salesPageActive Boolean   @default(false)

  // Lead magnet
  isLeadMagnet    Boolean   @default(false)
  downloadUrl     String?   // PDF file URL for lead magnet delivery
}

model SiteSettings {
  id                String  @id @default("global")
  leadMagnetEnabled Boolean @default(false)
}

model Newsletter {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
